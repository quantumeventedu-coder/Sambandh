{
  "name": "sambandh",
  "version": "0.1.0",
  "description": "Sambandh — verified, honesty-first dating platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:watch": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:setup": "node scripts/ensure-mongo-binary.js",
    "test:ci": "npm run test:setup && node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --ci --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "//config": "mongodb-memory-server: PIN the mongod version so the test substrate is deterministic (unpinned = whatever MongoDB released today), and put the binary in a fixed, cacheable dir so CI restores it instead of downloading mid-test.",
  "config": {
    "mongodbMemoryServer": {
      "version": "8.2.6",
      "downloadDir": "./.cache/mongodb-binaries"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "razorpay": "^2.9.4",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
