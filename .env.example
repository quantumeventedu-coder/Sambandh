# Sambandh — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# Values marked (dev) can stay as-is for local development.

# ---- Server ----
NODE_ENV=development
PORT=3010
FRONTEND_URL=

# ---- Database ----
# MongoDB Atlas connection string from cloud.mongodb.com.
# If unreachable, the server auto-starts an in-memory dev DB (data resets on restart).
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sambandh?retryWrites=true

# ---- JWT ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_random_hex_chars

# ---- Local development flags (REMOVE ALL of these before public launch) ----
DEV_MODE=true            # (dev) OTP shown on screen instead of real SMS
DEV_PAYMENTS=true        # (dev) payments simulated instead of live gateway
SEED_DEMO=true           # (dev) seeds demo users when the DB is empty
ADMIN_API_KEY=sambandh-admin-dev-key   # moderator panel key — CHANGE for production
SUPER_ADMIN_KEY=sambandh-super-dev-key # owner-only super admin key (full access incl. audited chat inspection) — CHANGE for production

# ---- Payments (Razorpay) — ALL PRICES ARE IN CHF ----
# Join fee: men CHF 1 · women CHF 5 · non-binary CHF 3 (one-time, no free tier)
# Sambandh+ CHF 6/mo · Premium CHF 15/mo · escalations CHF 0.50–1
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Karma Book AI (Anthropic) ----
ANTHROPIC_API_KEY=

# ---- SMS OTP (Firebase) — setting FIREBASE_PROJECT_ID enables production login ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- ID verification providers (automated engine; simulated in dev mode) ----
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
HYPERVERGE_APP_ID=
KARZA_API_KEY=

# ---- Photo/document storage (Cloudflare R2); local ./uploads used if empty ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sambandh-prod
R2_PUBLIC_URL=

# ---- Astrology (ProKerala) — internal approximation used if empty ----
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

# ---- NSFW image moderation ----
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# ---- Monitoring ----
SENTRY_DSN=

# ---- Email delivery (OTP + transactional). Unset = dev transport (logs to console). ----
# Either a full SMTP URL, or discrete host/port/user/pass. EMAIL_FROM sets the sender.
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Sambandh <no-reply@sambandh.app>

# ---- Web push (browser notifications). Unset = ephemeral dev keys (work locally). ----
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@sambandh.app

# ---- Google account login (optional). Get a client id from console.cloud.google.com. ----
GOOGLE_CLIENT_ID=
